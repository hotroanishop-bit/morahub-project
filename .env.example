# Database
DATABASE_URL="mysql://username:password@localhost:3306/morahub"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://yourdomain.com"
AUTH_SECRET="your-auth-secret-here"
AUTH_TRUST_HOST=true

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI API Keys (optional)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""

# SMTP Email (optional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="MoraHub <noreply@yourdomain.com>"

# Telegram Bot
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_URL="https://yourdomain.com/api/telegram/webhook"
